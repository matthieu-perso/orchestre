# =============================================================================
# Orchestre - Environment Variables
# Copy to .env and fill in your values.
# =============================================================================

# --- Required ---
# Session secret for cookies. Generate with: openssl rand -hex 32
SESSION_KEY=

# --- Production security (set when deploying) ---
# PRODUCTION=false
# CORS_ORIGINS=https://app.example.com
# STRICT_WEBHOOK_VERIFICATION=false

# --- Database (Docker Compose uses these) ---
POSTGRES_USER=orchestre
POSTGRES_PASSWORD=orchestre
POSTGRES_DB=orchestre
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Firebase (files: firebase-serviceaccount.json, firebase.json) ---
FIREBASE_STORAGE_BUCKET=
# Optional: Web API key for Auth REST API (or set in firebase.json as "apiKey")
# FIREBASE_API_KEY=

# --- LLMs ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
HUGGINGFACE_API_KEY=
HUGGINGFACE_ENDPOINT=

# --- Vector store ---
PINECONE_API_KEY=
PINECONE_PRODUCT_INDEX=
PINECONE_PRODUCT_ENVIRONMENT=

# --- Shopify ---
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_WEBHOOK_SECRET=
SHOPIFY_API_VERSION=2024-01

# --- Amazon SP-API ---
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=
AMAZON_REGION=us-east-1
AMAZON_ENDPOINT=https://sellingpartnerapi-na.amazon.com

# --- Amazon Ads ---
AMAZON_ADS_CLIENT_ID=
AMAZON_ADS_CLIENT_SECRET=

# --- Meta Ads ---
META_APP_ID=
META_APP_SECRET=

# --- Google Ads ---
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=

# --- Webhooks (base URL for registering with Shopify/Amazon) ---
WEBHOOK_BASE_URL=https://your-domain.com

# --- EasyPost (carrier labels) ---
EASYPOST_API_KEY=

# --- Alerts ---
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
ALERT_EMAIL_TO=
